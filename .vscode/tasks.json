{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "start-sql",
      "type": "shell",
      "command": "docker compose up -d sql --wait",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "test-all",
      "type": "shell",
      "command": "dotnet test RecipeLibrary.slnx",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "test-e2e",
      "type": "shell",
      "command": "dotnet test tests/RecipeLibrary.Web.E2E.Tests",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile",
      "group": "test"
    }
  ]
}
