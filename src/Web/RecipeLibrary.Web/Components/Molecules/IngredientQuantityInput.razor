@* Molecule: quantity input — whole, culinary fraction, or decimal (e.g. pounds). *@
@namespace RecipeLibrary.Components.Molecules

@if (string.IsNullOrWhiteSpace(UnitName))
{
    <span class="text-sm text-gray-400 px-1">—</span>
}
else if (_allowsCulinaryFractions)
{
    <div class="flex gap-1 min-w-0">
        <input type="number"
               class="@CssClass"
               min="0"
               step="1"
               inputmode="numeric"
               aria-label="@L["RecipeCreate.Ingredient.Quantity.Whole.AriaLabel"]"
               value="@_whole"
               @onchange="OnWholeChangedAsync" />
        <select class="@CssClass"
                aria-label="@L["RecipeCreate.Ingredient.Quantity.Fraction.AriaLabel"]"
                value="@_fractionKey"
                @onchange="OnFractionChangedAsync">
            @foreach (var option in CulinaryQuantityFractions.SelectOptions)
            {
                <option value="@option.Key">@option.Label</option>
            }
        </select>
    </div>
}
else if (_allowsDecimalQuantity)
{
    <input type="number"
           class="@CssClass"
           min="0.01"
           step="0.01"
           inputmode="decimal"
           value="@_decimalDisplay"
           @onchange="OnDecimalChangedAsync" />
}
else
{
    <input type="number"
           class="@CssClass"
           min="1"
           step="1"
           inputmode="numeric"
           value="@_wholeDisplay"
           @onchange="OnIntegerChangedAsync" />
}

@code {
    [Parameter] public decimal? Quantity { get; set; } = 1;
    [Parameter] public EventCallback<decimal?> QuantityChanged { get; set; }
    [Parameter] public EventCallback QuantityChangedAfter { get; set; }
    [Parameter] public string? UnitName { get; set; }
    [Parameter] public string? CssClass { get; set; }

    private bool _allowsCulinaryFractions;
    private bool _allowsDecimalQuantity;
    private int _whole;
    private string _fractionKey = "0";
    private int _wholeDisplay = 1;
    private string _decimalDisplay = "1";

    protected override void OnParametersSet()
    {
        _allowsCulinaryFractions = false;
        _allowsDecimalQuantity = false;
        Unit? parsedUnit = null;
        if (UnitRules.TryParse(UnitName, out var unit))
        {
            parsedUnit = unit;
            _allowsCulinaryFractions = UnitRules.AllowsCulinaryFractions(unit);
            _allowsDecimalQuantity = UnitRules.AllowsDecimalQuantity(unit);
        }

        var q = Quantity ?? 0m;
        if (_allowsCulinaryFractions)
        {
            var (whole, fraction) = CulinaryQuantityFractions.Split(q <= 0 ? 1m : q);
            _whole = whole;
            _fractionKey = CulinaryQuantityFractions.FractionKey(fraction);
        }
        else if (_allowsDecimalQuantity && parsedUnit is Unit decimalUnit)
        {
            var normalized = q <= 0 ? 1m : IngredientQuantityFormatter.Normalize(q, decimalUnit);
            // HTML type=number expects invariant decimals (dot), not locale commas.
            _decimalDisplay = normalized.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
        }
        else
        {
            _wholeDisplay = q <= 0
                ? 1
                : (int)decimal.Round(q, 0, MidpointRounding.AwayFromZero);
        }
    }

    private async Task OnIntegerChangedAsync(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        if (!int.TryParse(raw, System.Globalization.NumberStyles.Integer, System.Globalization.CultureInfo.InvariantCulture, out var parsed)
            && !int.TryParse(raw, System.Globalization.NumberStyles.Integer, System.Globalization.CultureInfo.CurrentCulture, out parsed))
        {
            return;
        }

        if (parsed < 1)
        {
            return;
        }

        await SetQuantityAsync(parsed);
    }

    private async Task OnDecimalChangedAsync(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        if (!decimal.TryParse(raw, System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.InvariantCulture, out var parsed)
            && !decimal.TryParse(raw, System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.CurrentCulture, out parsed))
        {
            return;
        }

        if (parsed <= 0 || !UnitRules.TryParse(UnitName, out var unit) || !UnitRules.AllowsDecimalQuantity(unit))
        {
            return;
        }

        var normalized = IngredientQuantityFormatter.Normalize(parsed, unit);
        _decimalDisplay = normalized.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
        await SetQuantityAsync(normalized);
    }

    private async Task OnWholeChangedAsync(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        if (!int.TryParse(raw, System.Globalization.NumberStyles.Integer, System.Globalization.CultureInfo.InvariantCulture, out var parsed)
            && !int.TryParse(raw, System.Globalization.NumberStyles.Integer, System.Globalization.CultureInfo.CurrentCulture, out parsed))
        {
            return;
        }

        if (parsed < 0)
        {
            return;
        }

        if (!CulinaryQuantityFractions.TryParseFractionKey(_fractionKey, out var fraction))
        {
            fraction = 0m;
        }

        var combined = CulinaryQuantityFractions.Combine(parsed, fraction);
        if (combined <= 0)
        {
            return;
        }

        _whole = parsed;
        await SetQuantityAsync(combined);
    }

    private async Task OnFractionChangedAsync(ChangeEventArgs e)
    {
        var key = e.Value?.ToString() ?? "0";
        if (!CulinaryQuantityFractions.TryParseFractionKey(key, out var fraction))
        {
            return;
        }

        var combined = CulinaryQuantityFractions.Combine(_whole, fraction);
        if (combined <= 0)
        {
            return;
        }

        _fractionKey = key;
        await SetQuantityAsync(combined);
    }

    private async Task SetQuantityAsync(decimal quantity)
    {
        Quantity = quantity;
        await QuantityChanged.InvokeAsync(Quantity);
        await QuantityChangedAfter.InvokeAsync();
    }
}
