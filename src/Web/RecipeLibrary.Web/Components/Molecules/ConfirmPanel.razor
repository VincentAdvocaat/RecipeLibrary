@* Molecule: yes/no confirmation panel. *@
@namespace RecipeLibrary.Components.Molecules

<div class="rounded border border-amber-200 bg-amber-50 p-4 space-y-3">
    <p class="text-sm text-amber-900">@Message</p>
    <div class="flex gap-3">
        <button type="button"
                data-testid="@UiTestIds.ConfirmYes"
                class="px-3 py-1.5 rounded bg-gray-800 text-white text-sm font-medium"
                @onclick="OnYes">
            @L["ShoppingList.Confirm.Yes"]
        </button>
        <button type="button"
                data-testid="@UiTestIds.ConfirmNo"
                class="px-3 py-1.5 rounded border border-gray-300 bg-white text-sm text-gray-700"
                @onclick="OnNo">
            @L["ShoppingList.Confirm.No"]
        </button>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Message { get; set; } = null!;
    [Parameter, EditorRequired] public EventCallback OnYes { get; set; }
    [Parameter, EditorRequired] public EventCallback OnNo { get; set; }
}
