@* Molecule: sign-in / sign-out for ASP.NET Core Identity. *@
@namespace RecipeLibrary.Components.Molecules
@using RecipeLibrary.Application.Abstractions

@inject NavigationManager Navigation
@inject ICurrentUser CurrentUser

<AuthorizeView>
    <Authorized>
        <span class="text-sm text-gray-600">@L["Auth.SignedInAs", CurrentUser.UserName ?? ""]</span>
        <form method="post" action="Account/Logout" class="inline">
            <AntiforgeryToken />
            <button type="submit" class="text-sm font-medium text-gray-700 hover:text-gray-900 bg-transparent border-0 cursor-pointer p-0">@L["Auth.SignOut"]</button>
        </form>
    </Authorized>
    <NotAuthorized>
        <a href="Account/Login" class="text-sm font-medium text-gray-700 hover:text-gray-900">@L["Auth.SignIn"]</a>
    </NotAuthorized>
</AuthorizeView>
