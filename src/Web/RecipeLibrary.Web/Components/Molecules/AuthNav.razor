@* Molecule: account avatar menu with sign-out (Identity cookie). *@
@namespace RecipeLibrary.Components.Molecules
@using RecipeLibrary.Application.Abstractions

@inject ICurrentUser CurrentUser

<AuthorizeView>
    <Authorized>
        <div class="relative @CssClass">
            @if (_isOpen)
            {
                <button type="button"
                        class="fixed inset-0 z-10 cursor-default"
                        tabindex="-1"
                        aria-hidden="true"
                        @onclick="Close"></button>
            }
            <button type="button"
                    id="account-menu-trigger"
                    data-testid="@UiTestIds.AccountMenu"
                    class="relative z-20 inline-flex h-9 w-9 items-center justify-center overflow-hidden rounded-full border border-gray-300 bg-gray-100 text-gray-600 hover:bg-gray-200 focus:outline-none focus:ring-2 focus:ring-gray-400 focus:ring-offset-1"
                    aria-haspopup="menu"
                    aria-expanded="@_isOpen"
                    aria-label="@L["Auth.AccountMenu.AriaLabel"]"
                    @onclick="Toggle">
                @if (!string.IsNullOrWhiteSpace(ProfileImageUrl))
                {
                    <img src="@ProfileImageUrl"
                         alt=""
                         class="h-full w-full object-cover"
                         width="36"
                         height="36" />
                }
                else
                {
                    <Icon Name="Icon.IconName.User" CssClass="h-5 w-5" />
                }
            </button>
            @if (_isOpen)
            {
                <div class="absolute right-0 z-20 mt-1 min-w-[12rem] rounded border border-gray-300 bg-white py-1 shadow-lg"
                     role="menu"
                     aria-labelledby="account-menu-trigger">
                    <div class="border-b border-gray-100 px-3 py-2">
                        <p class="truncate text-sm font-medium text-gray-900">@L["Auth.SignedInAs", CurrentUser.UserName ?? ""]</p>
                    </div>
                    <form method="post" action="/Account/Logout" class="block">
                        <AntiforgeryToken />
                        <button type="submit"
                                data-testid="@UiTestIds.AccountMenuSignOut"
                                class="flex w-full cursor-pointer items-center px-3 py-2 text-left text-sm text-gray-700 hover:bg-gray-50 bg-transparent border-0"
                                role="menuitem">
                            @L["Auth.SignOut"]
                        </button>
                    </form>
                </div>
            }
        </div>
    </Authorized>
    <NotAuthorized>
        <a href="/Account/Login"
           data-testid="@UiTestIds.AccountMenuSignIn"
           class="text-sm font-medium text-gray-700 hover:text-gray-900 @CssClass">@L["Auth.SignIn"]</a>
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool _isOpen;

    /// <summary>Optional profile photo URL; when empty the default user icon is shown.</summary>
    [Parameter] public string? ProfileImageUrl { get; set; }

    [Parameter] public string? CssClass { get; set; }

    private void Toggle() => _isOpen = !_isOpen;

    private void Close() => _isOpen = false;
}
