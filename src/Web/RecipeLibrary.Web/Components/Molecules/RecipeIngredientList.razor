@* Molecule: ingredients with quantity and unit for recipe detail. *@
@namespace RecipeLibrary.Components.Molecules

<div class="@CssClass">
    <Heading Level="3" CssClass="text-sm font-medium text-gray-900 mb-2">@L["Recipe.Ingredients.SectionLabel"]</Heading>
    <ul class="space-y-1 text-sm text-gray-700">
        @foreach (var item in Items)
        {
            <li class="flex flex-wrap gap-x-2">
                @if (!string.IsNullOrWhiteSpace(FormatMeasure(item)))
                {
                    <span class="font-medium tabular-nums">@FormatMeasure(item)</span>
                }
                <span>
                    @item.Name@if (!string.IsNullOrWhiteSpace(item.Preparation))
                    {
                        <span class="text-gray-500"> (@item.Preparation)</span>
                    }
                </span>
            </li>
        }
    </ul>
</div>

@code {
    [Parameter] public IReadOnlyList<RecipeDetailIngredientItem> Items { get; set; } = [];
    [Parameter] public string? CssClass { get; set; }

    private string FormatMeasure(RecipeDetailIngredientItem item)
    {
        if (item.Quantity is null || string.IsNullOrWhiteSpace(item.Unit))
        {
            return string.Empty;
        }

        var unit = UnitRules.TryParse(item.Unit, out var parsed) ? parsed : Unit.Unknown;
        var quantityText = unit == Unit.Unknown
            ? ((long)decimal.Round(item.Quantity.Value, 0, MidpointRounding.AwayFromZero))
                .ToString(System.Globalization.CultureInfo.InvariantCulture)
            : IngredientQuantityFormatter.Format(item.Quantity.Value, unit);
        return $"{quantityText} {GetUnitLabel(item.Unit)}";
    }

    private string GetUnitLabel(string unit)
    {
        var key = $"Recipe.Unit.{unit}";
        var localized = L[key];
        return localized.ResourceNotFound ? unit : localized.Value;
    }
}
