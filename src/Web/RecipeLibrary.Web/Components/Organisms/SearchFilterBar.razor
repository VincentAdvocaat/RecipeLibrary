@* Organism: search + view toggle + category filters (list layout). *@
@namespace RecipeLibrary.Components.Organisms

<div class="mb-6 space-y-4 rounded-lg border border-gray-200 bg-white p-4 @CssClass">
    <div class="flex flex-wrap items-center gap-4">
        <div class="flex-1 min-w-[200px] max-w-md">
            <SearchInput Value="@SearchQuery" ValueChanged="@SearchQueryChanged" />
        </div>
        <ViewToggle ViewMode="@ViewMode" ViewModeChanged="@ViewModeChanged" ShowCardsLabel="true" />
    </div>
    <CategoryFilter SelectedCategory="@SelectedCategory" SelectedCategoryChanged="@SelectedCategoryChanged" />
</div>

@code {
    [Parameter] public string? SearchQuery { get; set; }
    [Parameter] public EventCallback<string?> SearchQueryChanged { get; set; }
    [Parameter] public ViewToggle.ViewModeKind ViewMode { get; set; }
    [Parameter] public EventCallback<ViewToggle.ViewModeKind> ViewModeChanged { get; set; }
    [Parameter] public int? SelectedCategory { get; set; }
    [Parameter] public EventCallback<int?> SelectedCategoryChanged { get; set; }
    [Parameter] public string? CssClass { get; set; }
}
