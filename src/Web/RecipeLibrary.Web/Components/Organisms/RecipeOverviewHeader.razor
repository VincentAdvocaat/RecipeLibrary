@* Organism: page header with title, nav links, optional view toggle in header. *@
@namespace RecipeLibrary.Components.Organisms

<header class="flex flex-wrap items-center justify-between gap-4 mb-6 @CssClass">
    <div class="flex items-center gap-4">
        <Heading Level="1" CssClass="m-0">@Title</Heading>
        <nav class="flex items-center gap-4">
            @if (IsCreatePage)
            {
                <AppNavLink Href="/recipes" data-testid="@UiTestIds.NavRecipes">@L["Nav.MyRecipes"]</AppNavLink>
                <AppNavLink Href="/recipes/import">@L["Nav.ImportRecipe"]</AppNavLink>
                <AppNavLink Href="/">@L["Nav.Overview"]</AppNavLink>
            }
            else
            {
                <AppNavLink Href="/recipes/create" data-testid="@UiTestIds.NavCreate">@L["Nav.AddRecipe"]</AppNavLink>
                <AppNavLink Href="/recipes/import">@L["Nav.ImportRecipe"]</AppNavLink>
                <AppNavLink Href="/recipes" data-testid="@UiTestIds.NavRecipes">@L["Nav.MyRecipes"]</AppNavLink>
            }
            <a href="/shopping-list" data-testid="@UiTestIds.NavShoppingList" class="relative text-gray-700 text-sm font-medium hover:text-gray-900 no-underline">
                @L["Nav.ShoppingList"]
                @if (ShoppingBadgeCount > 0)
                {
                    <span data-testid="@UiTestIds.NavBadge" class="absolute -top-2 -right-3 inline-flex min-w-[1.25rem] items-center justify-center rounded-full bg-gray-800 px-1.5 py-0.5 text-xs font-medium text-white">
                        @ShoppingBadgeCount
                    </span>
                }
            </a>
            <AppNavLink Href="/pantry" data-testid="@UiTestIds.NavPantry">@L["Nav.Pantry"]</AppNavLink>
        </nav>
    </div>
    <div class="flex items-center gap-4">
        @if (ShowViewToggleInHeader)
        {
            <ViewToggle ViewMode="@ViewMode" ViewModeChanged="@ViewModeChanged" ShowCardsLabel="false" />
        }
        <AuthNav />
        <MeasureSystemSwitcher />
        <LanguageSwitcher />
    </div>
</header>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = null!;
    [Parameter] public bool IsCreatePage { get; set; }
    [Parameter] public bool ShowViewToggleInHeader { get; set; }
    [Parameter] public ViewToggle.ViewModeKind ViewMode { get; set; }
    [Parameter] public EventCallback<ViewToggle.ViewModeKind> ViewModeChanged { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public int ShoppingBadgeCount { get; set; }
}
