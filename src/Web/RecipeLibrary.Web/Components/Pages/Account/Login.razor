@page "/Account/Login"
@attribute [AllowAnonymous]
@attribute [ExcludeFromInteractiveRouting]
@layout RecipeLibrary.Components.Layout.AuthLayout

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Endpoints
@using Microsoft.AspNetCore.Identity
@using RecipeLibrary.Infrastructure.Identity

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<PageTitle>@L["Auth.Login.PageTitle"]</PageTitle>

<div class="mx-auto max-w-md space-y-6">
    <h1 class="text-2xl font-semibold text-gray-900">@L["Auth.Login.Heading"]</h1>

    <EditForm Model="Input" method="post" OnValidSubmit="HandleLoginAsync" FormName="login" Enhance="false">
        <DataAnnotationsValidator />

        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="text-sm text-red-600" role="alert">@_error</p>
        }

        <div class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700" for="login-email">@L["Auth.Email.Label"]</label>
                <InputText id="login-email" @bind-Value="Input.Email" class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2" autocomplete="username" />
                <ValidationMessage For="() => Input.Email" />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700" for="login-password">@L["Auth.Password.Label"]</label>
                <InputText id="login-password" type="password" @bind-Value="Input.Password" class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2" autocomplete="current-password" />
                <ValidationMessage For="() => Input.Password" />
            </div>
            <button type="submit" class="w-full rounded-md bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-800">
                @L["Auth.Login.Submit"]
            </button>
        </div>
    </EditForm>

    <p class="text-sm text-gray-600">
        @L["Auth.Login.NoAccount"]
        <a href="Account/Register" class="font-medium text-gray-900 hover:underline">@L["Auth.Register.Link"]</a>
    </p>
</div>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromForm]
    private LoginModel Input { get; set; } = default!;

    private string? _error;

    protected override void OnInitialized() => Input ??= new();

    private async Task HandleLoginAsync()
    {
        _error = null;

        var email = (Input.Email ?? string.Empty).Trim();
        var user = await UserManager.FindByEmailAsync(email);
        if (user is null)
        {
            _error = L["Auth.Login.InvalidCredentials"];
            return;
        }

        var result = await SignInManager.PasswordSignInAsync(
            user,
            Input.Password ?? string.Empty,
            isPersistent: true,
            lockoutOnFailure: true);

        if (!result.Succeeded)
        {
            _error = L["Auth.Login.InvalidCredentials"];
            return;
        }

        Navigation.NavigateTo(GetSafeReturnUrl(), forceLoad: true);
    }

    private string GetSafeReturnUrl()
    {
        if (!string.IsNullOrWhiteSpace(ReturnUrl)
            && ReturnUrl.StartsWith('/')
            && !ReturnUrl.StartsWith("//", StringComparison.Ordinal)
            && !ReturnUrl.Contains('\\'))
        {
            return ReturnUrl;
        }

        return "/recipes";
    }

    private sealed class LoginModel
    {
        [Required]
        [EmailAddress]
        public string? Email { get; set; }

        [Required]
        public string? Password { get; set; }
    }
}
