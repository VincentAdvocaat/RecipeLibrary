@page "/starting"
@attribute [AllowAnonymous]
@inject NavigationManager Navigation
@inject HttpClient Http
@implements IAsyncDisposable
@using System.Net.Http.Json
@using System.Text.Json.Serialization

<PageTitle>@L["Starting.PageTitle"]</PageTitle>

<div class="min-h-screen bg-gray-100 flex items-center justify-center p-4">
    <div class="max-w-lg w-full bg-white border border-gray-200 rounded-lg p-8 text-center shadow-sm"
         data-testid="starting-page"
         aria-busy="true">
        <div class="flex justify-center mb-5"
             role="status"
             aria-label="@L["Starting.Spinner.AriaLabel"]">
            <span class="inline-block h-10 w-10 rounded-full border-4 border-gray-200 border-t-gray-700 animate-spin"
                  aria-hidden="true"></span>
        </div>
        <h1 class="text-2xl font-semibold text-gray-900 mb-3">
            @L["Starting.Heading"]
        </h1>
        <p class="text-gray-600 mb-6">
            @L["Starting.Message"]
        </p>
        <p class="text-sm text-gray-500 mb-6" aria-live="polite">
            @L["Starting.Status"]
        </p>
        <button type="button"
                class="px-4 py-2 rounded border border-gray-300 bg-white text-sm text-gray-700 hover:bg-gray-50"
                @onclick="Reload">
            @L["Starting.RetryButton"]
        </button>
    </div>
</div>

@code {
    private CancellationTokenSource? _cts;

    protected override void OnInitialized()
    {
        _cts = new CancellationTokenSource();
        _ = PollUntilReadyAsync(_cts.Token);
    }

    private async Task PollUntilReadyAsync(CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested)
            {
                try
                {
                    var response = await Http.GetFromJsonAsync<SystemReadinessResponse>(
                        "api/system/readiness",
                        ct);

                    if (response is null)
                    {
                        await Task.Delay(TimeSpan.FromSeconds(5), ct);
                        continue;
                    }

                    if (string.Equals(response.State, "Ready", StringComparison.OrdinalIgnoreCase))
                    {
                        await InvokeAsync(() => Navigation.NavigateTo("/", forceLoad: true));
                        return;
                    }

                    if (string.Equals(response.State, "Failed", StringComparison.OrdinalIgnoreCase))
                    {
                        await InvokeAsync(() => Navigation.NavigateTo("/failed", forceLoad: true));
                        return;
                    }

                    var delaySeconds = response.RetryAfterSeconds is > 0
                        ? response.RetryAfterSeconds.Value
                        : 5;
                    await Task.Delay(TimeSpan.FromSeconds(delaySeconds), ct);
                }
                catch (HttpRequestException)
                {
                    await Task.Delay(TimeSpan.FromSeconds(5), ct);
                }
            }
        }
        catch (OperationCanceledException)
        {
            // Component disposed or app shutting down.
        }
    }

    private void Reload() => Navigation.NavigateTo("/starting", forceLoad: true);

    public async ValueTask DisposeAsync()
    {
        if (_cts is null)
        {
            return;
        }

        await _cts.CancelAsync();
        _cts.Dispose();
        _cts = null;
    }

    private sealed class SystemReadinessResponse
    {
        [JsonPropertyName("state")]
        public string? State { get; set; }

        [JsonPropertyName("retryAfterSeconds")]
        public int? RetryAfterSeconds { get; set; }
    }
}
