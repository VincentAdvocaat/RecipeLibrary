@page "/recipes/import"

@using System.Net.Http.Json
@using RecipeLibrary.Application.Contracts
@using RecipeLibrary.Resources
@using RecipeLibrary.Web.Models
@using RecipeLibrary.Web.Services
@inject HttpClient Http
@inject NavigationManager Navigation
@inject RecipeImportDraftService ImportDraft

<PageTitle>@L["RecipeImport.PageTitle"]</PageTitle>

<div class="min-h-screen bg-gray-100">
<div class="container mx-auto p-4 max-w-4xl">
        <RecipeOverviewHeader Title="@L["RecipeImport.PageTitle"]" IsCreatePage="true" />

        @if (!_showPreview)
        {
            <div class="bg-white rounded-lg shadow p-6 space-y-6">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">@L["RecipeImport.Paste.Label"]</label>
                    <textarea class="block w-full rounded border border-gray-300 px-3 py-2 text-sm font-mono"
                              rows="14"
                              placeholder="@L["RecipeImport.Paste.Placeholder"]"
                              @bind="_pasteContent"></textarea>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">@L["RecipeImport.Url.Label"]</label>
                    <input class="block w-full rounded border border-gray-300 px-3 py-2 text-sm"
                           placeholder="@L["RecipeImport.Url.Placeholder"]"
                           @bind="_url" />
                    <p class="mt-1 text-xs text-gray-500">@L["RecipeImport.Url.Hint"]</p>
                </div>

                @if (!string.IsNullOrWhiteSpace(_errorMessage))
                {
                    <p class="text-sm text-red-600">@_errorMessage</p>
                }

                <div class="flex flex-wrap justify-between gap-3">
                    <Button Variant="secondary" Text="@L["RecipeImport.CancelButton"]" OnClick="OnCancel" />
                    <button type="button"
                            class="inline-flex items-center px-4 py-2 rounded bg-gray-800 text-white text-sm font-medium hover:bg-gray-700 disabled:opacity-50"
                            disabled="@_isProcessing"
                            @onclick="ProcessImportAsync">
                        @L["RecipeImport.ProcessButton"]
                    </button>
                </div>
            </div>
        }
        else if (_result is not null)
        {
            <div class="bg-white rounded-lg shadow p-6 space-y-6">
                <p class="text-sm text-gray-600">@L["RecipeImport.Preview.Intro"]</p>

                @if (_result.Warnings.Count > 0)
                {
                    <div class="rounded border border-amber-200 bg-amber-50 p-3 space-y-1">
                        @foreach (var warning in _result.Warnings)
                        {
                            <p class="text-sm text-amber-800">@warning</p>
                        }
                    </div>
                }

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">@L["RecipeCreate.Title.Label"]</label>
                        <input class="block w-full rounded border border-gray-300 px-3 py-2 text-sm" @bind="_previewTitle" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">@L["RecipeImport.Source.Label"]</label>
                        <p class="text-sm text-gray-700">@GetSourceLabel(_result.Source)</p>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">@L["RecipeCreate.Description.Label"]</label>
                    <textarea class="block w-full rounded border border-gray-300 px-3 py-2 text-sm" rows="3" @bind="_previewDescription"></textarea>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">@L["RecipeCreate.PreparationTime.Label"]</label>
                        <input type="number" class="block w-full rounded border border-gray-300 px-3 py-2 text-sm" @bind="_previewPrepMinutes" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">@L["RecipeCreate.CookingTime.Label"]</label>
                        <input type="number" class="block w-full rounded border border-gray-300 px-3 py-2 text-sm" @bind="_previewCookMinutes" />
                    </div>
                </div>

                <div class="space-y-3">
                    <Heading Level="3" CssClass="text-sm font-medium text-gray-900">@L["RecipeCreate.Ingredients.SectionLabel"]</Heading>
                    @for (var i = 0; i < _previewIngredients.Count; i++)
                    {
                        var index = i;
                        var item = _previewIngredients[index];
                        var lowConfidence = item.Confidence < 0.7m;
                        <div class="@(lowConfidence ? "rounded border border-amber-300 bg-amber-50/40 p-2" : string.Empty)">
                            @if (lowConfidence)
                            {
                                <p class="text-xs text-amber-700 mb-2">
                                    @L["RecipeImport.Ingredient.LowConfidence", item.Confidence.ToString("P0"), GetParseMethodLabel(item.ParseMethod)]
                                </p>
                            }
                            <RecipeIngredientEditorRow Item="@item.EditorItem"
                                                     ItemChanged="@(_ => StateHasChanged())"
                                                     Suggestions="@GetIngredientSuggestions(index)"
                                                     MatchMessage="@GetIngredientMatchMessage(index)"
                                                     MatchMessageChanged="@(msg => SetIngredientMatchMessage(index, msg))"
                                                     OnNameChanged="@(name => OnIngredientNameSearch(index, name))"
                                                     CanRemove="@(_previewIngredients.Count > 1)"
                                                     OnRemove="@(() => RemoveIngredient(index))" />
                        </div>
                    }
                </div>

                <div class="space-y-3">
                    <Heading Level="3" CssClass="text-sm font-medium text-gray-900">@L["RecipeCreate.Instructions.SectionLabel"]</Heading>
                    @for (var i = 0; i < _previewSteps.Count; i++)
                    {
                        var step = _previewSteps[i];
                        <textarea class="block w-full rounded border border-gray-300 px-3 py-2 text-sm" rows="2" @bind="step.Text"></textarea>
                    }
                </div>

                <div class="flex flex-wrap justify-between gap-3 pt-4 border-t border-gray-200">
                    <Button Variant="secondary" Text="@L["RecipeImport.BackButton"]" OnClick="BackToInput" />
                    <button type="button"
                            class="inline-flex items-center px-4 py-2 rounded bg-gray-800 text-white text-sm font-medium hover:bg-gray-700"
                            @onclick="ContinueToCreate">
                        @L["RecipeImport.ContinueButton"]
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private sealed class PreviewIngredientRow
    {
        public RecipeIngredientEditorItem EditorItem { get; set; } = new();

        public decimal Confidence { get; set; }

        public ImportParseMethod ParseMethod { get; set; }
    }

    private string _pasteContent = string.Empty;
    private string? _url;
    private bool _isProcessing;
    private bool _showPreview;
    private string? _errorMessage;
    private ImportRecipeResult? _result;
    private string _previewTitle = string.Empty;
    private string? _previewDescription;
    private int _previewPrepMinutes = 30;
    private int _previewCookMinutes;
    private List<PreviewIngredientRow> _previewIngredients = [];
    private List<ImportedInstructionStep> _previewSteps = [];
    private readonly Dictionary<int, List<IngredientLookupItem>> _ingredientSuggestions = [];
    private readonly Dictionary<int, string> _ingredientMatchMessages = [];

    private async Task ProcessImportAsync()
    {
        _errorMessage = null;
        _isProcessing = true;

        try
        {
            ImportRecipeResult? result;
            if (!string.IsNullOrWhiteSpace(_url))
            {
                var response = await Http.PostAsJsonAsync("/recipes/import-url", new ImportRecipeFromUrlQuery { Url = _url.Trim() });
                if (!response.IsSuccessStatusCode)
                {
                    _errorMessage = await response.Content.ReadAsStringAsync();
                    return;
                }

                result = await response.Content.ReadFromJsonAsync<ImportRecipeResult>();
            }
            else
            {
                if (string.IsNullOrWhiteSpace(_pasteContent))
                {
                    _errorMessage = L["RecipeImport.Error.EmptyContent"];
                    return;
                }

                var response = await Http.PostAsJsonAsync(
                    "/recipes/import",
                    new ImportRecipeContentQuery { Content = _pasteContent, ContentKind = ImportContentKind.Auto });

                if (!response.IsSuccessStatusCode)
                {
                    _errorMessage = await response.Content.ReadAsStringAsync();
                    return;
                }

                result = await response.Content.ReadFromJsonAsync<ImportRecipeResult>();
            }

            if (result is null)
            {
                _errorMessage = L["RecipeImport.Error.NoResult"];
                return;
            }

            ApplyPreview(result);
            _showPreview = true;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private void ApplyPreview(ImportRecipeResult result)
    {
        _result = result;
        _previewTitle = result.Title ?? string.Empty;
        _previewDescription = result.Description;
        _previewPrepMinutes = result.PreparationTimeMinutes ?? 30;
        _previewCookMinutes = result.CookingTimeMinutes ?? 0;
        _previewIngredients = result.Ingredients.Select(x => new PreviewIngredientRow
        {
            Confidence = x.Confidence,
            ParseMethod = x.ParseMethod,
            EditorItem = new RecipeIngredientEditorItem
            {
                Name = x.Name,
                Preparation = x.Preparation,
                Quantity = x.Quantity,
                UnitName = x.Unit,
            },
        }).ToList();

        if (_previewIngredients.Count == 0)
        {
            _previewIngredients.Add(new PreviewIngredientRow());
        }

        _previewSteps = result.Steps.ToList();
        if (_previewSteps.Count == 0)
        {
            _previewSteps.Add(new ImportedInstructionStep { StepNumber = 1, Text = string.Empty });
        }

        _ingredientSuggestions.Clear();
        _ingredientMatchMessages.Clear();
        for (var i = 0; i < result.Ingredients.Count; i++)
        {
            var matchType = result.Ingredients[i].MatchType;
            if (string.IsNullOrWhiteSpace(matchType))
            {
                continue;
            }

            _ingredientMatchMessages[i] = matchType switch
            {
                "exact" => L["RecipeCreate.Ingredient.Match.Exact"],
                "alias" => L["RecipeCreate.Ingredient.Match.Alias"],
                "fuzzy" => L["RecipeCreate.Ingredient.Match.Fuzzy", result.Ingredients[i].Name, "—"],
                "none" => L["RecipeCreate.Ingredient.Match.None"],
                _ => string.Empty,
            };
        }
    }

    private void ContinueToCreate()
    {
        if (_result is null)
        {
            return;
        }

        var draft = new ImportRecipeResult
        {
            Title = _previewTitle,
            Description = _previewDescription,
            PreparationTimeMinutes = _previewPrepMinutes,
            CookingTimeMinutes = _previewCookMinutes,
            Source = _result.Source,
            Ingredients = _previewIngredients.Select(x => new ImportedIngredientLine
            {
                Name = x.EditorItem.Name,
                Preparation = x.EditorItem.Preparation,
                Quantity = x.EditorItem.Quantity,
                Unit = x.EditorItem.UnitName,
                Confidence = x.Confidence,
                ParseMethod = x.ParseMethod,
            }).ToList(),
            Steps = _previewSteps
                .Select((step, index) => new ImportedInstructionStep { StepNumber = index + 1, Text = step.Text })
                .ToList(),
            Warnings = _result.Warnings,
        };

        ImportDraft.SetDraft(draft);
        Navigation.NavigateTo("/recipes/create?fromImport=true");
    }

    private void BackToInput() => _showPreview = false;

    private void OnCancel() => Navigation.NavigateTo("/recipes");

    private void RemoveIngredient(int index)
    {
        if (_previewIngredients.Count <= 1) return;
        _previewIngredients.RemoveAt(index);
    }

    private IReadOnlyList<IngredientLookupItem> GetIngredientSuggestions(int index) =>
        _ingredientSuggestions.TryGetValue(index, out var suggestions) ? suggestions : [];

    private string? GetIngredientMatchMessage(int index) =>
        _ingredientMatchMessages.TryGetValue(index, out var message) ? message : null;

    private Task SetIngredientMatchMessage(int index, string? message)
    {
        if (string.IsNullOrWhiteSpace(message))
        {
            _ingredientMatchMessages.Remove(index);
        }
        else
        {
            _ingredientMatchMessages[index] = message;
        }

        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task OnIngredientNameSearch(int index, string name)
    {
        var query = name.Trim();
        if (query.Length < 2)
        {
            _ingredientSuggestions[index] = [];
            StateHasChanged();
            return;
        }

        var encoded = Uri.EscapeDataString(query);
        var suggestions = await Http.GetFromJsonAsync<List<IngredientLookupItem>>($"/ingredients/search?q={encoded}") ?? [];
        _ingredientSuggestions[index] = suggestions;
        StateHasChanged();
    }

    private string GetSourceLabel(ImportSource source) => source switch
    {
        ImportSource.JsonLd => L["RecipeImport.Source.JsonLd"],
        ImportSource.PlainText => L["RecipeImport.Source.PlainText"],
        ImportSource.Mixed => L["RecipeImport.Source.Mixed"],
        _ => L["RecipeImport.Source.Unknown"],
    };

    private string GetParseMethodLabel(ImportParseMethod method) => method switch
    {
        ImportParseMethod.Ai => L["RecipeImport.ParseMethod.Ai"],
        ImportParseMethod.Structured => L["RecipeImport.ParseMethod.Structured"],
        _ => L["RecipeImport.ParseMethod.Deterministic"],
    };
}
