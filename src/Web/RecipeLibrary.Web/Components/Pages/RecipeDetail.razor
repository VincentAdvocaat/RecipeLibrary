@page "/recipes/{RecipeId:guid}"
@rendermode InteractiveServer

@inject IQueryBus QueryBus
@inject ICommandBus CommandBus
@inject ShoppingListSessionService ShoppingSession
@inject NavigationManager Navigation

@if (_recipe is null && !_redirected)
{
    <p class="p-4 text-gray-600">@L["RecipeDetail.Loading"]</p>
}
else if (_recipe is not null)
{
    <PageTitle>@L["RecipeDetail.PageTitle", _recipe.Title]</PageTitle>

    <div class="min-h-screen bg-gray-100">
        <div class="container mx-auto p-4 max-w-4xl">
            <header class="flex flex-wrap items-center justify-between gap-4 mb-6">
                <div class="flex flex-col gap-2">
                    <AppNavLink Href="/recipes">@L["RecipeDetail.BackToOverview"]</AppNavLink>
                    <Heading Level="1" CssClass="m-0">@_recipe.Title</Heading>
                </div>
                <div class="flex items-center gap-3">
                    <AuthNav />
                    <LanguageSwitcher />
                </div>
            </header>

            <div class="bg-white rounded-lg shadow overflow-hidden">
                @if (!string.IsNullOrEmpty(_recipe.ImageUrl))
                {
                    <div class="aspect-video w-full max-h-80 overflow-hidden">
                        <Image Src="@_recipe.ImageUrl" Alt="@_recipe.Title" CssClass="w-full h-full object-cover" />
                    </div>
                }

                <div class="p-6 space-y-6">
                    @if (!string.IsNullOrEmpty(_recipe.Description))
                    {
                        <p class="text-gray-700">@_recipe.Description</p>
                    }

                    <div class="flex flex-wrap items-center gap-4">
                        <span class="inline-flex px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800">
                            @GetCategoryLabel(_recipe.Category)
                        </span>
                        <RecipeMeta PreparationMinutes="@_recipe.PreparationMinutes" CookingMinutes="@_recipe.CookingMinutes" Servings="@_recipe.Servings" DifficultyLevel="@_recipe.Difficulty" />
                    </div>

                    @if (_recipe.Ingredients.Count > 0)
                    {
                        <RecipeIngredientList Items="@_recipe.Ingredients" />
                    }

                    @if (_recipe.Steps.Count > 0)
                    {
                        <div>
                            <Heading Level="3" CssClass="text-sm font-medium text-gray-900 mb-2">@L["RecipeDetail.Instructions.SectionLabel"]</Heading>
                            <ol class="list-decimal list-inside space-y-2 text-sm text-gray-700">
                                @foreach (var step in _recipe.Steps)
                                {
                                    <li class="pl-1">@step.Text</li>
                                }
                            </ol>
                        </div>
                    }

                    @if (_ingredientTags.Count > 0)
                    {
                        <div>
                            <Heading Level="3" CssClass="text-sm font-medium text-gray-900 mb-2">@L["RecipeDetail.Tags.SectionLabel"]</Heading>
                            <div class="flex flex-wrap gap-2">
                                @foreach (var tag in _ingredientTags)
                                {
                                    <span class="inline-flex px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-700">@tag</span>
                                }
                            </div>
                        </div>
                    }

                    @if (_addMessage is not null)
                    {
                        <p class="text-sm text-green-700">@_addMessage <AppNavLink Href="/shopping-list">@L["Nav.ShoppingList"]</AppNavLink></p>
                    }

                    <div class="flex flex-wrap items-end gap-3 pt-4 border-t border-gray-200">
                        @if (_shoppingLists.Count > 1)
                        {
                            <div>
                                <label class="block text-xs text-gray-600 mb-1">@L["RecipeDetail.AddToShoppingList.TargetLabel"]</label>
                                <select class="rounded border border-gray-300 text-sm px-2 py-1.5"
                                        @bind="_targetShoppingListId">
                                    @foreach (var list in _shoppingLists)
                                    {
                                        <option value="@list.Id">@list.Name</option>
                                    }
                                </select>
                            </div>
                        }
                        <button type="button"
                                data-testid="@UiTestIds.AddToShoppingList"
                                class="px-3 py-1.5 rounded bg-gray-800 text-white text-sm font-medium"
                                @onclick="AddToShoppingListAsync">
                            @L["RecipeDetail.AddToShoppingListButton"]
                        </button>
                        <AppNavLink Href="@($"/recipes/{_recipe.Id}/edit")" data-testid="@UiTestIds.RecipeEdit">@L["RecipeDetail.EditButton"]</AppNavLink>
                        <button type="button"
                                data-testid="@UiTestIds.RecipeDelete"
                                class="text-sm font-medium text-red-600 hover:text-red-800"
                                @onclick="ConfirmDelete">
                            @L["RecipeDetail.DeleteButton"]
                        </button>
                    </div>

                    @if (_showDeleteConfirm)
                    {
                        <div class="rounded border border-red-200 bg-red-50 p-4 space-y-3">
                            <p class="text-sm text-red-800">@L["RecipeDetail.DeleteConfirm.Message"]</p>
                            <div class="flex gap-3">
                                <button type="button"
                                        data-testid="@UiTestIds.DeleteConfirmYes"
                                        class="px-3 py-1.5 rounded bg-red-600 text-white text-sm font-medium hover:bg-red-700"
                                        @onclick="DeleteRecipeAsync">
                                    @L["RecipeDetail.DeleteConfirm.ConfirmButton"]
                                </button>
                                <button type="button"
                                        data-testid="@UiTestIds.DeleteConfirmNo"
                                        class="px-3 py-1.5 rounded border border-gray-300 bg-white text-sm text-gray-700 hover:bg-gray-50"
                                        @onclick="() => _showDeleteConfirm = false">
                                    @L["RecipeDetail.DeleteConfirm.CancelButton"]
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid RecipeId { get; set; }

    private GetRecipeByIdResult? _recipe;
    private IReadOnlyList<string> _ingredientTags = [];
    private IReadOnlyList<ShoppingListDto> _shoppingLists = [];
    private Guid _targetShoppingListId;
    private bool _redirected;
    private bool _showDeleteConfirm;
    private string? _addMessage;

    protected override async Task OnInitializedAsync()
    {
        var result = await QueryBus.QueryAsync<GetRecipeByIdQuery, GetRecipeByIdResult?>(
            new GetRecipeByIdQuery { RecipeId = RecipeId });

        if (result is null)
        {
            _redirected = true;
            Navigation.NavigateTo("/not-found");
            return;
        }

        _recipe = result;
        await LoadIngredientTagsAsync();
        await LoadShoppingListsAsync();
    }

    private async Task LoadShoppingListsAsync()
    {
        var group = await ShoppingSession.GetOrCreateGroupAsync();
        _shoppingLists = group.Lists.OrderBy(l => l.StoreOrder).ToList();
        _targetShoppingListId = _shoppingLists.FirstOrDefault()?.Id ?? Guid.Empty;
    }

    private async Task AddToShoppingListAsync()
    {
        if (_targetShoppingListId == Guid.Empty)
        {
            return;
        }

        await CommandBus.SendAsync<AddRecipesToShoppingListCommand, AddRecipesToShoppingListResult>(
            new AddRecipesToShoppingListCommand
            {
                ShoppingListId = _targetShoppingListId,
                RecipeIds = [RecipeId],
            });

        _addMessage = L["RecipeDetail.AddedToShoppingList.Message"];
    }

    private async Task LoadIngredientTagsAsync()
    {
        _ingredientTags = await QueryBus.QueryAsync<GetRecipeIngredientTagsQuery, IReadOnlyList<string>>(
            new GetRecipeIngredientTagsQuery { RecipeId = RecipeId });
    }

    private string GetCategoryLabel(int category) => category switch
    {
        1 => L["Category.Vegetarian.Label"],
        2 => L["Category.Meat.Label"],
        3 => L["Category.Vegan.Label"],
        _ => L["Category.All.Label"],
    };

    private void ConfirmDelete() => _showDeleteConfirm = true;

    private async Task DeleteRecipeAsync()
    {
        await CommandBus.SendAsync<DeleteRecipeCommand, DeleteRecipeResult>(
            new DeleteRecipeCommand { RecipeId = RecipeId });
        Navigation.NavigateTo("/recipes");
    }
}
