{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RecipeFileStorage": {
    "LocalBasePath": ""
  },
  "RecipeImport": {
    "Ai": {
      "Enabled": false,
      "Model": "gpt-4o-mini",
      "ConfidenceThreshold": 0.7
    },
    "UrlFetch": {
      "TimeoutSeconds": 10,
      "MaxBytes": 524288
    }
  }
}
