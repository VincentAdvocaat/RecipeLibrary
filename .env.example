# Required for local SQL Server container (Docker) and for local debug (app uses this for ConnectionStrings__RecipeDb fallback).
# - At least 8 chars, contains upper, lower, digit, and a symbol.
# - Example (DON'T use in real setups): RecipeLibrary!123
MSSQL_SA_PASSWORD=ChangeMe!123

# Optional: OpenAI for recipe import AI fallback (local only — never commit real keys).
# RecipeImport__Ai__Enabled=true
# RecipeImport__Ai__ApiKey=sk-your-key-here
# RecipeImport__Ai__TimeoutSeconds=120

# Optional: YouTube Data API v3 key for Shorts/video description import (local only — never commit real keys).
# See docs/azure/youtube-keyvault.md.
# RecipeImport__YouTube__ApiKey=AIzaSy...

# Optional: override directory for recipe image uploads (default: RecipeLibraryUploads folder one level above app content root).
# RecipeFileStorage__LocalBasePath=C:\path\to\uploads
