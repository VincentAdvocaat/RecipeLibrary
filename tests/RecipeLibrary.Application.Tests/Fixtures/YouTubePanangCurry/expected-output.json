  "instructionSteps": [
    {
      "stepNumber": 1,
      "text": "Heat half of 14oz can coconut milk in a deep pan on medium heat for 2-3 minutes."
    },
    {
      "stepNumber": 2,
      "text": "Once slightly thickened, add curry paste and stir. Once incorporated, simmer on medium low for 5-6 minutes until the coconut milk makes a bright red oil with the curry paste."
    },
    {
      "stepNumber": 3,
      "text": "Add sliced chicken thigh and stir so the chicken is coated in the curry mixture."
    },
    {
      "stepNumber": 4,
      "text": "Add coconut milk, and 3-4 torn kaffir lime leaves."
    },
    {
      "stepNumber": 5,
      "text": "Cover and simmer on medium low heat for 10-15 minutes until the chicken is fully cooked through. Make sure to occasionally stir so the bottom doesn\u2019t burn."
    },
    {
      "stepNumber": 6,
      "text": "Season to taste with fish sauce and palm sugar."
    },
    {
      "stepNumber": 7,
      "text": "Garnish with minced kaffir lime leaves, sliced red chillies, and enjoy with hot rice."
    }
  ]
