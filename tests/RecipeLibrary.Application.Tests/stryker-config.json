{
  "stryker-config": {
    "project": "RecipeLibrary.Application.csproj",
    "mutate": [
      "**/ShoppingLists/ShoppingListAccessGuard.cs",
      "**/ShoppingLists/ShoppingListIngredientMerger.cs",
      "**/Ingredients/IngredientMatcher.cs",
      "**/Ingredients/IngredientSimilarityScorer.cs",
      "**/Ingredients/IngredientLineParser.cs"
    ],
    "reporters": [
      "html",
      "json",
      "cleartext",
      "progress"
    ],
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 0
    },
    "verbosity": "info",
    "ignore-methods": [
      "*ToString",
      "*GetHashCode"
    ]
  }
}
